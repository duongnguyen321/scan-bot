TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Free API keys (get from each explorer)
ETHERSCAN_API_KEY=your_etherscan_api_key
BSCSCAN_API_KEY=${ETHERSCAN_API_KEY}
POLYGONSCAN_API_KEY=${ETHERSCAN_API_KEY}
ARBISCAN_API_KEY=${ETHERSCAN_API_KEY}

# Tronscan - Optional but recommended to avoid rate limits
# Get key: https://tronscan.org/#/myaccount/apiKeys
# Header used: TRON-PRO-API-KEY
TRONSCAN_API_KEY=
